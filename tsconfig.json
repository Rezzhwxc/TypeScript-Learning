{
  "compilerOptions": {
    "outDir": "./dist",    // Куда складывать готовые .js файлы
    "rootDir": "./src",    // Где искать исходные .ts файлы

    "allowJs": true,       // Разрешить компилировать и .js файлы, если нужно
    "strict": true,         // Включает все строгие проверки (у тебя уже есть)
    "noUnusedLocals": true,  // Предупреждает, если объявил переменную, но не используешь.
    "noUnusedParameters": true, // То же самое для параметров функции.

    "target": "ES2022",    // Версия JavaScript на выходе
    "module": "commonjs"   // Система модулей (для Node.js)
  },
  "include": ["src/**/*"]  // Какие файлы компилировать
}